{
  "name": "@mcptoolshop/prism-verify",
  "version": "1.2.0",
  "description": "prism-verify — runtime LLM verifier (family-different, reasoning-stripped, multi-lens, signed Ed25519 receipts). Zero-prerequisite npx install via a verified binary launcher.",
  "type": "commonjs",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "prism": "bin/prism.js"
  },
  "files": [
    "bin/",
    "README.md",
    "README.*.md",
    "LICENSE"
  ],
  "scripts": {
    "verify": "node -e \"require('./bin/prism.js')\" 2>&1 || true"
  },
  "keywords": [
    "llm",
    "verification",
    "verifier",
    "adjudication",
    "mcp",
    "agent",
    "cli"
  ],
  "dependencies": {
    "@mcptoolshop/npm-launcher": "^1.0.0"
  },
  "author": "mcp-tool-shop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-tool-shop-org/prism-verify.git"
  },
  "homepage": "https://github.com/mcp-tool-shop-org/prism-verify"
}
